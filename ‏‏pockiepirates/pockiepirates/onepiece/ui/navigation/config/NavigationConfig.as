      public static function getCell(cellId:int = 1001) : String
      {
         var cell:XML = null;
         var result:String = null;
         cell = warCell.war.(@id == cellId)[0];
         result = cell.toString();
         return result;
      }
      
      public static function getNpcInfo(_id:int) : XML
      {
         var cell:XML = null;
         cell = warCell.person.(@id == _id)[0];
         return cell;
      }
